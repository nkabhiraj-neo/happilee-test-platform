{
  "name": "happilee-test-platform",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "test:e2e": "cucumber-js --config e2e/cucumber.config.cjs",
    "test:e2e:video": "cross-env E2E_RECORD_FULL_RUN=1 cucumber-js --config e2e/cucumber.config.cjs",
    "test:e2e:report": "cross-env E2E_RECORD_VIDEO=1 cucumber-js --config e2e/cucumber.config.cjs --format html:e2e/reports/report.html",
    "qa": "node scripts/run-qa.mjs",
    "qa:auth": "node scripts/run-qa.mjs --auth-only",
    "qa:project": "node scripts/run-qa.mjs --proj-only",
    "qa:headed": "cross-env E2E_HEADED=1 node scripts/run-qa.mjs",
    "qa:auth:headed": "cross-env E2E_HEADED=1 node scripts/run-qa.mjs --auth-only",
    "qa:project:headed": "cross-env E2E_HEADED=1 node scripts/run-qa.mjs --proj-only",
    "test:e2e:qa": "cross-env E2E_RECORD_FULL_RUN=1 node scripts/run-e2e-with-report.mjs",
    "test:e2e:jira": "cross-env E2E_JIRA_CREATE=1 node scripts/post-e2e-failures.mjs",
    "test:e2e:github": "cross-env E2E_GITHUB_CREATE=1 node scripts/post-e2e-failures.mjs",
    "test:e2e:tickets": "cross-env E2E_JIRA_CREATE=1 E2E_GITHUB_CREATE=1 node scripts/post-e2e-failures.mjs",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "qa:dashboard": "npx --yes serve e2e/reports -p 4000",
    "sync:jira": "npx ts-node --project tsconfig.scripts.json scripts/sync-jira.ts",
    "sync:jira:reverse": "npx ts-node --project tsconfig.scripts.json scripts/sync-jira.ts --reverse",
    "generate-video-index": "node scripts/generate-video-index.mjs"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@cucumber/html-formatter": "^21.7.0",
    "@playwright/test": "^1.51.1",
    "@types/node": "^24.10.1",
    "cross-env": "^7.0.3",
    "playwright": "^1.51.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3"
  }
}
